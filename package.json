{
  "name": "@sygnal/nextra-docs-engine",
  "version": "0.1.0",
  "description": "Shared Nextra 4 + Next.js 15 docs engine — components, styles, breadcrumb, mdx-components factory, authoring skill.",
  "type": "module",
  "files": [
    "dist",
    "skill",
    "templates",
    "scripts/sync-skill.mjs",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./skill/SKILL.md": "./skill/SKILL.md",
    "./templates/*": "./templates/*",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-assets.mjs && node scripts/prune-peer-deps.mjs",
    "postinstall": "node scripts/sync-skill.mjs",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "next": "15.5.4",
    "nextra": "4.6.0",
    "nextra-theme-docs": "4.6.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "next": "15.5.4",
    "nextra": "4.6.0",
    "nextra-theme-docs": "4.6.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
